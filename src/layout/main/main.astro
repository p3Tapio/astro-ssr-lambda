---
import "../../style/pico.scss";
import "../../style/global.scss";
import "./main.scss";

import Links from "./links.astro";

interface MainLayoutProps {
  title?: string;
  h1?: string;
}

const { title, h1 }: MainLayoutProps = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ? `Astro | ${title}` : "Astro"}</title>
  </head>
  <body>
    <main class="container">
      <div class="container__header">
        {h1 && <h1>{h1}</h1>}
        <button class="nav-toggle" id="mobile-toggle"></button>
        <nav class="nav desktop">
          <Links />
        </nav>
        <nav class="nav mobile" id="mobile-nav">
          <Links />
        </nav>
      </div>
      <slot />
    </main>
    <script>
      const button = document.getElementById("mobile-toggle");
      const nav = document.getElementById("mobile-nav");

      button?.addEventListener("click", () => {
        nav?.classList.toggle("open");
      });

      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (nav && !nav.contains(target) && !button?.contains(target)) {
          nav.classList.remove("open");
        }
      });
    </script>
  </body>
</html>
