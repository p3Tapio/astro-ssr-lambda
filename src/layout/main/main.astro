---
import { ClientRouter } from "astro:transitions";

import "../../style/pico.scss";
import "../../style/global.scss";
import "./main.scss";

import Links from "./links.astro";

interface MainLayoutProps {
  title?: string;
  h1?: string;
}

const { title, h1 }: MainLayoutProps = Astro.props;
---

<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="utf-8" />
    <style is:inline>
      /* inlined  some color to mitigate fouc*/
      :root {
        color-scheme: light dark;
      }
      body {
        background-color: #fff;
        @media (prefers-color-scheme: dark) {
          background-color: rgb(19, 22.5, 30.5);
        }
      }
    </style>
    <link
      rel="icon"
      type="image/svg+xml"
      href="/assets/favicon.svg"
      data-astro-transition-persist="favicon"
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ? `Astro | ${title}` : "Astro"}</title>
  </head>
  <body>
    <main class="container">
      <div class="container__header">
        {h1 && <h1>{h1}</h1>}
        <button class="nav-toggle" id="mobile-toggle"></button>
        <nav class="nav desktop">
          <Links />
        </nav>
        <nav class="nav mobile" id="mobile-nav">
          <Links />
        </nav>
      </div>
      <slot />
    </main>
    <script is:inline>
      function initMobileNav() {
        const button = document.getElementById("mobile-toggle");
        const nav = document.getElementById("mobile-nav");

        button?.addEventListener("click", () => {
          nav?.classList.toggle("open");
        });

        document.addEventListener("click", (e) => {
          if (nav && !nav.contains(e.target) && !button?.contains(e.target)) {
            nav.classList.remove("open");
          }
        });
      }
      document.addEventListener("astro:page-load", initMobileNav);
    </script>
  </body>
</html>
